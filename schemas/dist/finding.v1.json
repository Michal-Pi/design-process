{
  "$id": "https://complete-design.dev/schemas/finding.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A diagnostic finding produced by a gate or audit check",
  "properties": {
    "evidence": {
      "additionalProperties": false,
      "properties": {
        "line": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "findingId": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*-\\d+$",
      "type": "string"
    },
    "fixRecipe": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "BLOCKER",
        "WARN",
        "INFO"
      ],
      "type": "string"
    },
    "suppression": {
      "type": "string"
    }
  },
  "required": [
    "findingId",
    "severity",
    "evidence",
    "fixRecipe"
  ],
  "title": "Finding",
  "type": "object"
}
