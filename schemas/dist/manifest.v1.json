{
  "$id": "https://complete-design.dev/schemas/manifest.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "MANIFEST.md frontmatter + per-artifact entry index; consumed by manifest-reconcile.mjs",
  "properties": {
    "artifact": {
      "const": "manifest",
      "type": "string"
    },
    "entries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "artifact": {
            "minLength": 1,
            "type": "string"
          },
          "dependents": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "generated": {
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "stage": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "path",
          "artifact",
          "stage",
          "generated",
          "dependents"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "generated": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "lastReviewedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "owner": {
      "minLength": 1,
      "type": "string"
    },
    "provenance": {
      "enum": [
        "generated",
        "validated",
        "inferred",
        "missing"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "sourceHash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "stage": {
      "const": "cross-stage",
      "type": "string"
    },
    "worstProvenance": {
      "enum": [
        "generated",
        "validated",
        "inferred",
        "missing"
      ],
      "type": "string"
    }
  },
  "required": [
    "artifact",
    "stage",
    "schemaVersion",
    "sourceHash",
    "generated",
    "provenance",
    "owner",
    "lastReviewedAt",
    "entries"
  ],
  "title": "Manifest (cross-stage)",
  "type": "object"
}
