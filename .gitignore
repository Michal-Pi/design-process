.DS_Store
*.swp
*.tmp
.idea/
.vscode/
node_modules/
__pycache__/
*.pyc
.env
.env.local
.complete-design/private/
# Runtime-generated .complete-design/ directories inside test fixtures
# Exceptions: recovery + governance fixtures have committed manifest.lock files
tests/fixtures/**/.complete-design/
!tests/fixtures/recovery/**/.complete-design/
!tests/fixtures/recovery/**/.complete-design/manifest.lock
!tests/fixtures/governance/**/.complete-design/
!tests/fixtures/governance/**/.complete-design/manifest.lock
evals/bundles/**/.complete-design/
evals/bundles/last-run.json
# Runtime-generated .handoff/ directories inside golden fixtures
evals/fixtures/golden/**/.handoff/
*.log
# dist/ is excluded but schemas/dist/ is intentionally committed (D-02 versioning policy)
/dist/
.tsc-out/
# Top-level design/ is e2e run output (generated by `design --route` during manual testing).
# evals/fixtures/design-dirs/ and tests/fixtures/ are intentionally tracked — not affected.
/design/
