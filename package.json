{
  "name": "design-os",
  "version": "0.1.0",
  "description": "5-stage design process, operationalized as an agent-loop workflow",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "design-os": "./bin/design-os.mjs"
  },
  "scripts": {
    "schemas:emit": "tsx assets/scripts/schemas/emit.mjs",
