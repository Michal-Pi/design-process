    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8",
    "ajv-formats": "^3",
    "apca-w3": "latest",
    "commander": "^12",
    "culori": "^4",
    "get-port": "^7",
    "globby": "^14",
    "gray-matter": "^4",
    "pino": "^9",
    "semver": "^7",
    "tiktoken": "^1",
    "wcag-contrast": "^3",
    "yaml": "^2",
    "zod": "^4.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/semver": "^7",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^2"
  },
  "license": "Apache-2.0"
