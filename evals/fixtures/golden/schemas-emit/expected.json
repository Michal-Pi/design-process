{
  "$id": "https://complete-design.dev/schemas/persona.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Indi Young thinking-style format with NN/g provenance gating (RED-04 carrier)",
  "properties": {
    "artifact": {
      "const": "persona",
      "type": "string"
    },
    "generated": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "jobsToBeDone": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "lastReviewedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "owner": {
      "minLength": 1,
      "type": "string"
    },
    "provenance": {
      "enum": [
        "generated",
        "validated",
        "inferred",
        "missing"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "sourceHash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "stage": {
      "const": "1",
      "type": "string"
    },
    "thinkingStyle": {
      "additionalProperties": false,
      "properties": {
        "cognitiveSpace": {
          "minLength": 1,
          "type": "string"
        },
        "emotionalReactions": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "guidingPrinciples": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "cognitiveSpace",
        "emotionalReactions",
        "guidingPrinciples"
      ],
      "type": "object"
    },
    "worstProvenance": {
      "enum": [
        "generated",
        "validated",
        "inferred",
        "missing"
      ],
      "type": "string"
    }
  },
  "required": [
    "artifact",
    "stage",
    "schemaVersion",
    "sourceHash",
    "generated",
    "provenance",
    "owner",
    "lastReviewedAt",
    "name",
    "jobsToBeDone",
    "thinkingStyle"
  ],
  "title": "Persona (Stage 1)",
  "type": "object"
}
